{
  "schemaVersion": "hermes.skill-contract.v0",
  "id": "shared.text-extract.v0",
  "name": "Extract Text",
  "namespace": "shared",
  "status": "dev",
  "summary": "Extract text and page/section anchors from local documents.",
  "inputs": {
    "localFiles": "shared.local-file-resolve-documents.v0.outputs.localFiles",
