{
  "schemaVersion": "workflow.definition.v0",
  "id": "document-onboarding",
  "name": "Document Onboarding",
  "status": "dev",
  "domain": "legal",
  "sourceSystem": {
    "name": "orchestratorai-local",
    "references": [
      "apps/api/src/legal/legal-department.graph.ts",
      "apps/api/src/legal/workflows/document-onboarding/brief.md",
      "apps/api/src/legal/workflows/document-onboarding/user-guide.md",
      "apps/api/src/legal/workflows/document-onboarding/document-onboarding.presentation.ts",
      "apps/api/src/legal/workflows/document-onboarding/document-onboarding-substrate.service.ts",
      "tests/integration/fixtures/flagship/document-onboarding.fixture.json"
    ],
    "notes": [
      "Current OrchestratorAI Local document-onboarding runs through the shared legal-department graph.",
      "The legacy flow has one HITL checkpoint and a final report/export path.",
      "Default job routing maps document-analysis jobs to document-onboarding."
    ]
  },
  "description": "Select one or more matter documents, extract and classify their legal metadata, route to legal specialists, synthesize cross-domain findings, pause for attorney review, then produce a final document onboarding report and routing recommendations.",
  "operatingMode": {
    "style": "fire-and-forget",
    "expectedDuration": "90 seconds to 2 minutes on demo hardware; longer for larger multi-document packets",
    "humanInteraction": "single checkpoint after synthesis and before final report generation"
  },
  "frontend": {
    "launchModes": [
      {
        "id": "legal-source-picker",
        "name": "Choose Client Matter Documents",
        "description": "Browse clients, matters, and matter documents from the Apple local database or a Hermes-backed external source.",
        "steps": [
          "search-or-select-client",
          "search-or-select-matter",
          "select-one-or-more-documents",
          "queue-workflow"
        ],
        "preferred": true
      },
      {
        "id": "local-file-picker",
        "name": "Choose Local Files",
        "description": "Select local files or a local matter folder as the Mac/Hermes runtime sees them, then attach optional client and matter context.",
        "steps": [
          "choose-files-or-folder",
          "attach-client-context",
          "attach-matter-context",
          "queue-workflow"
        ]
      },
      {
        "id": "upload",
        "name": "Upload Files",
        "description": "Fallback path when the documents are not already in a known client/matter source."
      }
    ],
    "displayContract": {
      "clientSummary": [
        "id",
        "slug",
        "name",
        "clientType",
        "industry",
        "matterCount"
      ],
      "matterSummary": [
        "id",
        "slug",
        "name",
        "clientId",
        "clientName",
        "matterType",
        "status",
        "jurisdiction",
        "documentCount"
      ],
      "documentSummary": [
        "id",
        "slug",
        "name",
        "documentClass",
        "documentDate",
        "summary",
        "parties",
        "keyTerms",
        "sourceKind",
        "sourceUri"
      ]
    }
  },
  "runtime": {
    "engine": "hermes",
    "workflowSkill": "workflow.run-structured-graph.v0",
    "legacyEquivalent": "legal-department langgraph",
    "observability": {
      "mode": "apple-local-database",
      "presentationStages": [
        "metadata",
        "classify",
        "specialists",
        "synthesis",
        "hitl_review",
        "report"
      ],
      "events": [
        "workflow.started",
        "stage.started",
        "stage.completed",
        "work_unit.started",
        "work_unit.completed",
        "human_review.requested",
        "human_review.completed",
        "workflow.completed",
        "workflow.failed"
      ]
    }
  },
  "modelPolicy": {
    "defaultRoute": "local",
    "sovereignty": "local-first",
    "defaultLocalModel": "qwen3.6:35b-a3b-nvfp4",
    "allowedRoutes": [
      "local",
      "ollama-cloud",
      "codex-subscription",
      "google-subscription",
      "claude-subscription"
    ],
    "credentialPolicy": {
      "mode": "bring-your-own-key",
      "requiredFor": [
        "ollama-cloud",
        "google-subscription",
        "claude-subscription"
      ],
      "codex-subscription": "use-user-authenticated-codex-where-available"
    },
    "confidentialityRules": [
      {
        "classification": "client-confidential",
        "allowedRoutes": [
          "local"
        ],
        "fallbackBehavior": "fail-with-explanation"
      },
      {
        "classification": "demo-or-public",
        "allowedRoutes": [
          "local",
          "ollama-cloud",
          "codex-subscription",
          "google-subscription",
          "claude-subscription"
        ],
        "fallbackBehavior": "ask-user"
      }
    ],
    "notes": [
      "Local Ollama providers may serialize specialist calls, so eight specialists can run sequentially.",
      "Cloud-capable routes may parallelize specialists if workflow policy permits.",
      "Cloud providers are available only when the organization/user supplies credentials and the workflow data classification permits cloud use."
    ]
  },
  "inputs": {
    "legalSourceSelection": {
      "type": "object",
      "required": false,
      "fields": {
        "clientId": "string",
        "clientSlug": "string",
        "matterId": "string",
        "matterSlug": "string",
        "documentIds": "string[]",
        "documentSlugs": "string[]",
        "storagePaths": "string[]",
        "sourceUris": "string[]"
      },
      "description": "Preferred launch contract from the legal source picker. It snapshots the client, matter, selected documents, and file pointers used for the run."
    },
    "documents": {
      "type": "file_set",
      "required": true,
      "limits": {
        "maxFiles": 10
      },
      "supportedTypes": [
        "native_pdf",
        "scanned_pdf",
        "docx",
        "docx_tracked_changes",
        "pptx",
        "text",
        "markdown",
        "json",
        "csv",
        "image"
      ],
      "description": "Documents selected from a matter substrate source or uploaded directly."
    },
    "fileSystemDocuments": {
      "type": "object",
      "required": false,
      "fields": {
        "clientId": "string",
        "clientSlug": "string",
        "matterId": "string",
        "matterSlug": "string",
        "filePaths": "string[]",
        "baseDirectory": "string",
        "sourceUris": "string[]"
      },
      "description": "Local-safe copy of client or matter documents addressed by file path. This is the expected Apple/Hermes path when the lawyer or student has downloaded documents to their machine."
    },
    "substrateSelection": {
      "type": "object",
      "required": false,
      "fields": {
        "orgSlug": "string",
        "clientId": "string",
        "clientSlug": "string",
        "matterId": "string",
        "matterSlug": "string",
        "documentSlugs": "string[]"
      },
      "description": "Optional configured-firm source selection. The local workflow resolves matter and document rows, then snapshots source data into the job."
    },
    "manualUpload": {
      "type": "file_set",
      "required": false,
      "description": "Fallback path when documents are outside the configured source."
    },
    "reviewInstructions": {
      "type": "markdown",
      "required": false,
      "description": "Optional reviewer lens, feedback, or rerun instructions."
    }
  },
  "outputs": {
    "primary": [
      {
        "id": "response",
        "type": "markdown",
        "description": "Final user-facing report text."
      },
      {
        "id": "document-onboarding-report",
        "type": "export_document",
        "formats": [
          "markdown",
          "docx",
          "pdf"
        ],
        "description": "Exportable Document Onboarding Report."
      }
    ],
    "structured": [
      {
        "id": "documentsMetadata",
        "type": "json",
        "description": "Document type, parties, dates, signatures, sections, confidence values, and source references."
      },
      {
        "id": "routingDecision",
        "type": "json",
        "description": "CLO routing decision selecting specialist lanes."
      },
      {
        "id": "specialistOutputs",
        "type": "json",
        "description": "Per-specialist findings across contract, compliance, IP, privacy, employment, corporate, litigation, and real-estate lanes."
      },
      {
        "id": "synthesis",
        "type": "json",
        "description": "Executive summary, risk matrix, recommendations, cross-document findings, and next-workflow routing."
      }
    ],
    "review": [
      {
        "id": "reviewPayload",
        "type": "json",
        "description": "HITL payload containing specialistOutputs, synthesis, and documentsSummary."
      }
    ]
  },
  "skillNamespaces": {
    "workflow": [
      "workflow.load-definition.v0",
      "workflow.validate-definition.v0",
      "workflow.resolve-inputs.v0",
      "workflow.run-structured-graph.v0",
      "workflow.persist-run-observability.v0",
      "workflow.request-human-review.v0",
      "workflow.apply-human-review-decision.v0",
      "workflow.render-output-packet.v0",
      "workflow.export-document.v0",
      "workflow.ingest-output-to-rag.v0"
    ],
    "shared": [
      "shared.substrate-resolve-matter-documents.v0",
      "shared.local-file-resolve-documents.v0",
      "shared.file-ingest.v0",
      "shared.text-extract.v0",
      "shared.ocr-if-needed.v0",
      "shared.docx-tracked-changes-extract.v0",
      "shared.schema-validate.v0",
      "shared.write-artifacts.v0"
    ],
    "legalShared": [
      "legal.shared.list-clients.v0",
      "legal.shared.list-matters.v0",
      "legal.shared.list-matter-documents.v0",
      "legal.shared.apple-store-resolve-client-matter.v0",
      "legal.shared.extract-document-metadata.v0",
      "legal.shared.classify-document-type.v0",
      "legal.shared.detect-sections.v0",
      "legal.shared.detect-signatures.v0",
      "legal.shared.extract-dates.v0",
      "legal.shared.extract-parties.v0",
      "legal.shared.clo-route-specialists.v0",
      "legal.shared.specialist.contract-review.v0",
      "legal.shared.specialist.compliance-review.v0",
      "legal.shared.specialist.ip-review.v0",
      "legal.shared.specialist.privacy-review.v0",
      "legal.shared.specialist.employment-review.v0",
      "legal.shared.specialist.corporate-review.v0",
      "legal.shared.specialist.litigation-review.v0",
      "legal.shared.specialist.real-estate-review.v0"
    ],
    "legalWorkflow": [
      "legal.workflow.document-onboarding.v0",
      "legal.workflow.document-onboarding.synthesize-findings.v0",
      "legal.workflow.document-onboarding.recommend-next-workflow.v0"
    ]
  },
  "graphs": [
    {
      "id": "intake-and-metadata",
      "name": "Intake And Metadata",
      "presentationStage": "metadata",
      "purpose": "Resolve selected or uploaded documents, extract text, and create the legal metadata needed for routing.",
      "subgraphs": [
        {
          "id": "source-resolution",
          "name": "Source Resolution",
          "workUnits": [
            {
              "id": "resolve-client-matter-context",
              "name": "Resolve Client And Matter Context",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.apple-store-resolve-client-matter.v0"
              },
              "inputs": [
                "inputs.legalSourceSelection.clientId",
                "inputs.legalSourceSelection.clientSlug",
                "inputs.legalSourceSelection.matterId",
                "inputs.legalSourceSelection.matterSlug",
                "inputs.fileSystemDocuments.clientId",
                "inputs.fileSystemDocuments.clientSlug",
                "inputs.fileSystemDocuments.matterId",
                "inputs.fileSystemDocuments.matterSlug",
                "inputs.substrateSelection.clientId",
                "inputs.substrateSelection.clientSlug",
                "inputs.substrateSelection.matterId",
                "inputs.substrateSelection.matterSlug"
              ],
              "outputs": [
                "run.source.client",
                "run.source.matter"
              ],
              "optional": true,
              "successCriteria": [
                "Client and matter context are resolved when identifiers are provided.",
                "The run records whether context came from the Apple local database, a Hermes-backed external source, or user input.",
                "Missing client or matter records become review warnings rather than silent assumptions."
              ]
            },
            {
              "id": "resolve-substrate-documents",
              "name": "Resolve Matter Documents",
              "assignee": {
                "type": "skill",
                "skill": "shared.substrate-resolve-matter-documents.v0"
              },
              "inputs": [
                "inputs.substrateSelection"
              ],
              "outputs": [
                "run.source.matter",
                "run.source.documents"
              ],
              "optional": true,
              "successCriteria": [
                "Matter slug resolves to one matter.",
                "Every selected document slug resolves to text and source metadata."
              ]
            },
            {
              "id": "resolve-local-file-documents",
              "name": "Resolve Local File Documents",
              "assignee": {
                "type": "skill",
                "skill": "shared.local-file-resolve-documents.v0"
              },
              "inputs": [
                "inputs.fileSystemDocuments.baseDirectory",
                "inputs.fileSystemDocuments.filePaths",
                "inputs.fileSystemDocuments.sourceUris",
                "inputs.legalSourceSelection.storagePaths",
                "inputs.legalSourceSelection.sourceUris",
                "run.source.client",
                "run.source.matter"
              ],
              "outputs": [
                "run.source.localFiles"
              ],
              "optional": true,
              "successCriteria": [
                "Every file path is normalized to a stable local reference.",
                "Paths outside the allowed local workspace are rejected or require explicit approval.",
                "Each local file is linked to client and matter context when available."
              ]
            },
            {
              "id": "ingest-uploaded-files",
              "name": "Ingest Uploaded Files",
              "assignee": {
                "type": "skill",
                "skill": "shared.file-ingest.v0"
              },
              "inputs": [
                "inputs.manualUpload",
                "inputs.documents"
              ],
              "outputs": [
                "run.source.uploads"
              ],
              "optional": true,
              "successCriteria": [
                "Each upload has a stable local reference.",
                "Unsupported or unreadable files are reported with reasons."
              ]
            },
            {
              "id": "extract-document-text",
              "name": "Extract Document Text",
              "assignee": {
                "type": "skill",
                "skill": "shared.text-extract.v0"
              },
              "fallbackSkills": [
                "shared.ocr-if-needed.v0",
                "shared.docx-tracked-changes-extract.v0"
              ],
              "inputs": [
                "run.source.localFiles",
                "run.source.documents",
                "run.source.uploads"
              ],
              "outputs": [
                "run.documents.text"
              ],
              "successCriteria": [
                "Native PDFs use the text layer.",
                "Scanned PDFs route through OCR.",
                "DOCX tracked insertions and deletions are preserved for downstream review."
              ]
            }
          ]
        },
        {
          "id": "metadata-extraction",
          "name": "Metadata Extraction",
          "workUnits": [
            {
              "id": "extract-legal-metadata",
              "name": "Extract Legal Metadata",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.extract-document-metadata.v0"
              },
              "inputs": [
                "run.documents.text"
              ],
              "outputs": [
                "outputs.documentsMetadata"
              ],
              "successCriteria": [
                "Document type, sections, signatures, dates, and parties are attempted for every document.",
                "Confidence values are included.",
                "Metadata extraction failure does not automatically fail the whole workflow; routing may continue with lower confidence."
              ],
              "composedOf": [
                "legal.shared.classify-document-type.v0",
                "legal.shared.detect-sections.v0",
                "legal.shared.detect-signatures.v0",
                "legal.shared.extract-dates.v0",
                "legal.shared.extract-parties.v0"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "classification-and-specialist-routing",
      "name": "Classification And Specialist Routing",
      "presentationStage": "classify",
      "dependsOn": [
        "intake-and-metadata"
      ],
      "purpose": "Classify the document package and select the legal specialist lanes that should review it.",
      "subgraphs": [
        {
          "id": "clo-routing",
          "name": "CLO Routing",
          "workUnits": [
            {
              "id": "route-specialists",
              "name": "Route Specialists",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.clo-route-specialists.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "inputs.reviewInstructions"
              ],
              "outputs": [
                "outputs.routingDecision"
              ],
              "successCriteria": [
                "Routing decision explains which specialist lanes are selected and why.",
                "Low-confidence classification broadens specialist coverage rather than narrowing it prematurely."
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "specialist-review",
      "name": "Specialist Review",
      "presentationStage": "specialists",
      "dependsOn": [
        "classification-and-specialist-routing"
      ],
      "purpose": "Run legal-domain specialists against the document packet and gather findings.",
      "execution": {
        "mode": "fanout",
        "localFallback": "sequential"
      },
      "subgraphs": [
        {
          "id": "specialist-lanes",
          "name": "Specialist Lanes",
          "workUnits": [
            {
              "id": "contract-specialist",
              "name": "Contract Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.contract-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.contract"
              ]
            },
            {
              "id": "compliance-specialist",
              "name": "Compliance Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.compliance-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.compliance"
              ]
            },
            {
              "id": "ip-specialist",
              "name": "IP Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.ip-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.ip"
              ]
            },
            {
              "id": "privacy-specialist",
              "name": "Privacy Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.privacy-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.privacy"
              ]
            },
            {
              "id": "employment-specialist",
              "name": "Employment Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.employment-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.employment"
              ]
            },
            {
              "id": "corporate-specialist",
              "name": "Corporate Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.corporate-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.corporate"
              ]
            },
            {
              "id": "litigation-specialist",
              "name": "Litigation Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.litigation-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.litigation"
              ]
            },
            {
              "id": "real-estate-specialist",
              "name": "Real Estate Specialist",
              "assignee": {
                "type": "skill",
                "skill": "legal.shared.specialist.real-estate-review.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision"
              ],
              "outputs": [
                "outputs.specialistOutputs.realEstate"
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "synthesis-review-and-report",
      "name": "Synthesis, Review, And Report",
      "dependsOn": [
        "specialist-review"
      ],
      "purpose": "Combine findings, pause for attorney review, and generate final work product.",
      "subgraphs": [
        {
          "id": "synthesis",
          "name": "Synthesis",
          "presentationStage": "synthesis",
          "workUnits": [
            {
              "id": "synthesize-findings",
              "name": "Synthesize Findings",
              "assignee": {
                "type": "skill",
                "skill": "legal.workflow.document-onboarding.synthesize-findings.v0"
              },
              "inputs": [
                "run.documents.text",
                "outputs.documentsMetadata",
                "outputs.routingDecision",
                "outputs.specialistOutputs"
              ],
              "outputs": [
                "outputs.synthesis"
              ],
              "successCriteria": [
                "Output leads with risk matrix and action-ready recommendations.",
                "Multi-document packets are compared together.",
                "Cross-domain issues are surfaced rather than siloed by specialist."
              ]
            }
          ]
        },
        {
          "id": "attorney-review",
          "name": "Attorney Review",
          "presentationStage": "hitl_review",
          "workUnits": [
            {
              "id": "request-attorney-review",
              "name": "Request Attorney Review",
              "assignee": {
                "type": "skill",
                "skill": "workflow.request-human-review.v0"
              },
              "inputs": [
                "outputs.specialistOutputs",
                "outputs.synthesis",
                "outputs.documentsMetadata"
              ],
              "outputs": [
                "outputs.reviewPayload",
                "run.humanReview.decision"
              ],
              "humanInTheLoop": {
                "required": true,
                "statusWhilePaused": "awaiting_review",
                "allowedDecisions": [
                  "approve",
                  "reject",
                  "modify"
                ],
                "decisionEndpointEquivalent": "POST /legal-department/jobs/:id/review",
                "rejectBehavior": "rerun-specialist-review-with-feedback",
                "modifyBehavior": "apply-reviewer-edits-then-report"
              },
              "successCriteria": [
                "Automated output does not become final work product without attorney action.",
                "Review payload includes specialistOutputs, synthesis, and documentsSummary."
              ]
            }
          ]
        },
        {
          "id": "report",
          "name": "Report",
          "presentationStage": "report",
          "workUnits": [
            {
              "id": "generate-final-report",
              "name": "Generate Final Report",
              "assignee": {
                "type": "skill",
                "skill": "workflow.render-output-packet.v0"
              },
              "inputs": [
                "run.humanReview.decision",
                "outputs.synthesis",
                "outputs.documentsMetadata",
                "outputs.specialistOutputs"
              ],
              "outputs": [
                "outputs.response"
              ],
              "successCriteria": [
                "Final report includes executive summary, document classification, risk matrix, and recommendations.",
                "Recommendations can point to Contract Review, Compliance Audit, Discovery Review, Due Diligence, or Matter Planning."
              ]
            },
            {
              "id": "export-final-report",
              "name": "Export Final Report",
              "assignee": {
                "type": "skill",
                "skill": "workflow.export-document.v0"
              },
              "inputs": [
                "outputs.response",
                "outputs.documentsMetadata"
              ],
              "outputs": [
                "outputs.document-onboarding-report"
              ],
              "successCriteria": [
                "Markdown, DOCX, and PDF export formats can be generated from the same export document contract."
              ]
            },
            {
              "id": "recommend-next-workflow",
              "name": "Recommend Next Workflow",
              "assignee": {
                "type": "skill",
                "skill": "legal.workflow.document-onboarding.recommend-next-workflow.v0"
              },
              "inputs": [
                "outputs.synthesis",
                "outputs.documentsMetadata"
              ],
