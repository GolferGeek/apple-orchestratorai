{
  "schemaVersion": "workflow.execution-plan.v0",
  "kind": "workflow.execution-plan",
  "workflowId": "document-onboarding",
  "profileId": "legal-dev",
  "mode": "golden-path",
  "sourceWorkflow": "workflows/legal/document-onboarding.workflow.json",
  "stages": [
    {
      "id": "metadata",
      "name": "Metadata",
      "graphId": "intake-and-metadata",
      "subgraphId": "source-resolution",
      "execution": "sequential",
      "workUnits": [
        {
          "id": "resolve-client-matter-context",
          "name": "Resolve Client And Matter Context",
          "skillId": "legal.shared.apple-store-resolve-client-matter.v0",
          "inputs": ["launch.source.client", "launch.source.matter"],
          "outputs": ["run.source.client", "run.source.matter"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed"]
        },
        {
          "id": "resolve-local-file-documents",
          "name": "Resolve Local File Documents",
          "skillId": "shared.local-file-resolve-documents.v0",
          "inputs": ["launch.source.baseDirectory", "launch.source.filePaths", "launch.source.sourceUris", "run.source.client", "run.source.matter"],
          "outputs": ["run.source.localFiles"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed"]
        },
        {
          "id": "extract-document-text",
          "name": "Extract Document Text",
          "skillId": "shared.text-extract.v0",
          "inputs": ["run.source.localFiles"],
          "outputs": ["run.documents.text"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed"]
        },
        {
          "id": "extract-legal-metadata",
          "name": "Extract Legal Metadata",
          "skillId": "legal.shared.extract-document-metadata.v0",
          "inputs": ["run.documents.text", "run.source.client", "run.source.matter"],
          "outputs": ["outputs.documentsMetadata"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed", "stage.completed"]
        }
      ]
    },
    {
      "id": "classify",
      "name": "Classify",
      "graphId": "classification-and-specialist-routing",
      "subgraphId": "clo-routing",
      "execution": "sequential",
      "workUnits": [
        {
          "id": "route-specialists",
          "name": "Route Specialists",
          "skillId": "legal.shared.clo-route-specialists.v0",
          "inputs": ["run.documents.text", "outputs.documentsMetadata", "launch.instructions"],
          "outputs": ["outputs.routingDecision"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed", "stage.completed"]
        }
      ]
    },
    {
      "id": "specialists",
      "name": "Specialists",
      "graphId": "specialist-review",
      "subgraphId": "specialist-lanes",
      "execution": "fanout",
      "workUnits": [
        {
          "id": "run-specialist-lanes",
          "name": "Run Specialist Lanes",
          "skillId": "legal.shared.specialist-review.v0",
          "inputs": ["run.documents.text", "outputs.documentsMetadata", "outputs.routingDecision", "launch.instructions"],
          "outputs": ["outputs.specialistOutputs"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed", "stage.completed"]
        }
      ]
    },
    {
      "id": "synthesis",
      "name": "Synthesis",
      "graphId": "synthesis-review-and-report",
      "subgraphId": "synthesis",
      "execution": "sequential",
      "workUnits": [
        {
          "id": "synthesize-findings",
          "name": "Synthesize Findings",
          "skillId": "legal.workflow.document-onboarding.synthesize-findings.v0",
          "inputs": ["run.documents.text", "outputs.documentsMetadata", "outputs.routingDecision", "outputs.specialistOutputs"],
          "outputs": ["outputs.synthesis"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed", "stage.completed"]
        },
        {
          "id": "recommend-next-workflow",
          "name": "Recommend Next Workflow",
          "skillId": "legal.workflow.document-onboarding.recommend-next-workflow.v0",
          "inputs": ["outputs.synthesis", "outputs.routingDecision"],
          "outputs": ["outputs.nextWorkflowRecommendations"],
          "optional": true,
          "emits": ["work_unit.started", "work_unit.completed"]
        }
      ]
    },
    {
      "id": "hitl_review",
      "name": "Human Review",
      "graphId": "synthesis-review-and-report",
      "subgraphId": "attorney-review",
      "execution": "human-gated",
      "workUnits": [
        {
          "id": "request-attorney-review",
          "name": "Request Attorney Review",
          "skillId": "workflow.request-human-review.v0",
          "inputs": ["outputs.specialistOutputs", "outputs.synthesis", "outputs.documentsMetadata"],
          "outputs": ["outputs.reviewPayload", "run.humanReview.decision"],
          "optional": false,
          "emits": ["human_review.requested", "approval.request", "human_review.completed", "stage.completed"]
        }
      ]
    },
    {
      "id": "report",
      "name": "Report",
      "graphId": "synthesis-review-and-report",
      "subgraphId": "report-generation",
      "execution": "sequential",
      "workUnits": [
        {
          "id": "render-document-onboarding-report",
          "name": "Render Document Onboarding Report",
          "skillId": "workflow.render-output-packet.v0",
          "inputs": ["outputs.documentsMetadata", "outputs.routingDecision", "outputs.specialistOutputs", "outputs.synthesis", "run.humanReview.decision"],
          "outputs": ["outputs.response", "outputs.document-onboarding-report"],
          "optional": false,
          "emits": ["work_unit.started", "work_unit.completed", "stage.completed", "workflow.completed"]
        }
      ]
    }
  ],
  "humanCheckpoints": [
    {
      "id": "attorney-review",
      "stageId": "hitl_review",
      "reviewMode": "segmented",
      "allowedDecisions": ["approve", "request_changes", "reject"]
    }
  ]
}
