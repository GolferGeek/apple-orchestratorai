{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestratorai.local/schemas/workflows/workflow-run.v0.schema.json",
  "title": "Workflow Run Record v0",
  "type": "object",
  "required": [
    "id",
    "workflowId",
    "workflowName",
    "status",
    "profileId",
    "startedAt",
    "client",
    "matter",
    "stages",
    "outputs"
  ],
  "properties": {
    "id": { "type": "string" },
    "workflowId": { "type": "string" },
    "workflowName": { "type": "string" },
    "status": { "enum": ["queued", "running", "paused", "waiting_for_human", "completed", "failed", "cancelled", "stopped"] },
    "profileId": { "type": "string" },
    "startedAt": { "type": "string", "format": "date-time" },
    "completedAt": { "type": ["string", "null"], "format": "date-time" },
    "client": { "$ref": "display-envelope.v0.schema.json#/$defs/displayEntity" },
    "matter": { "$ref": "display-envelope.v0.schema.json#/$defs/displayEntity" },
    "stages": {
      "type": "array",
      "items": { "$ref": "display-envelope.v0.schema.json#/$defs/stage" }
    },
    "humanReview": {
      "oneOf": [
        { "$ref": "human-review.v0.schema.json" },
        { "type": "null" }
      ]
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "display-envelope.v0.schema.json#/$defs/output" }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "type", "runId"],
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "type": { "type": "string" },
          "runId": { "type": "string" },
          "workflowId": { "type": "string" },
          "stageId": { "type": "string" },
          "graphId": { "type": "string" },
          "subgraphId": { "type": "string" },
          "workUnitId": { "type": "string" },
          "skillId": { "type": "string" },
          "reviewId": { "type": "string" },
          "status": { "type": "string" },
          "summary": { "type": "string" },
          "message": { "type": "string" },
          "progress": {
            "type": "object",
            "required": ["current", "total", "unit"],
            "properties": {
              "current": { "type": "number" },
              "total": { "type": "number" },
              "unit": { "type": "string" }
            },
            "additionalProperties": false
          },
          "metrics": { "type": "object" },
          "outputs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "type"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "uri": { "type": ["string", "null"] },
                "title": { "type": ["string", "null"] }
              },
              "additionalProperties": false
            }
          },
          "raw": { "type": "object" },
          "rawHermesRunId": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "rawHermesRunId": { "type": "string" },
    "rawEventUri": { "type": "string" }
  },
  "additionalProperties": false
}
