{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestratorai.local/schemas/workflows/dynamic-agent-spec.v0.schema.json",
  "title": "Dynamic Agent Spec v0",
  "type": "object",
  "required": ["id", "name", "role", "instructions", "outputContract"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9.-]*[a-z0-9]$"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "instructions": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowedTools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "model": {
      "type": "string"
    },
    "modelTier": {
      "enum": ["fast", "standard", "reasoning", "deep"]
    },
    "outputContract": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
