{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestratorai.local/schemas/workflows/work-team.v0.schema.json",
  "title": "Work Team v0",
  "type": "object",
  "required": ["schemaVersion", "kind", "workflowId", "teams"],
  "properties": {
    "schemaVersion": { "const": "workflow.work-team.v0" },
    "kind": { "const": "workflow.work-teams" },
    "workflowId": { "type": "string" },
    "sourceWorkflow": { "type": "string" },
    "teams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "purpose", "execution", "roles"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "execution": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": { "enum": ["single", "sequential", "parallel", "fanout", "human-gated", "arbitrated"] },
              "localFallback": { "enum": ["sequential", "single", "none"] },
              "maxConcurrency": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "name", "agentId", "responsibility"],
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "agentId": { "type": "string" },
                "responsibility": { "type": "string" },
                "required": { "type": "boolean" },
                "when": { "type": "string" },
                "skills": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "tools": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "outputs": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": false
            }
          },
          "arbitration": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "agentId": { "type": "string" },
              "requiredWhen": {
                "type": "array",
                "items": { "type": "string" }
              },
              "output": { "type": "string" }
            },
            "additionalProperties": false
          },
          "events": {
            "type": "array",
            "items": { "type": "string" }
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
