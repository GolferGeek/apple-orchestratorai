{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orchestratorai.local/schemas/workflows/workflow-explanation.v0.schema.json",
  "title": "Workflow Explanation v0",
  "type": "object",
  "required": ["schema_version", "kind", "workflow_id", "target", "title", "summary", "sections", "actions"],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "kind": {
      "const": "workflow.explanation"
    },
    "workflow_id": {
      "type": "string"
    },
    "target": {
      "type": "object",
      "required": ["type", "id"],
      "properties": {
        "type": {
          "enum": ["workflow", "graph", "subgraph", "work_unit", "output"]
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "items"],
        "properties": {
          "heading": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label"],
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
