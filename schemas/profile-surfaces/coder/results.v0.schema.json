{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "profile.coder.results.v0",
  "title": "Coder Results Profile Surface",
  "type": "object",
  "required": ["schemaVersion", "profileId", "surfaceId", "appId", "generatedAt", "results"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "profileId": { "const": "coder" },
    "surfaceId": { "const": "results" },
    "appId": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["effortId", "title", "status", "summary"],
        "properties": {
          "effortId": { "type": "string" },
          "title": { "type": "string" },
          "status": { "enum": ["current", "future", "archive"] },
          "summary": { "type": "string" },
          "artifactCount": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
