{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "profile.coder.questions.v0",
  "title": "Coder Questions Profile Surface",
  "type": "object",
  "required": ["schemaVersion", "profileId", "surfaceId", "appId", "generatedAt", "questions"],
  "properties": {
    "schemaVersion": { "const": "0.1.0" },
    "profileId": { "const": "coder" },
    "surfaceId": { "const": "questions" },
    "appId": { "type": "string" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "effortId", "question", "blocking", "status"],
        "properties": {
          "id": { "type": "string" },
          "effortId": { "type": "string" },
          "question": { "type": "string" },
          "blocking": { "type": "boolean" },
          "status": { "enum": ["open", "answered", "dismissed"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
