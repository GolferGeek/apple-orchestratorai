      "expectedInterfaces": [
        "cli",
        "sdk"
      ],
      "responsibilities": [
        "admin-frontend",
        "coding-harness",
        "runtime-maintenance"
      ]
    },
    {
      "id": "ollama",
      "required": false,
      "managedBy": "shared-apple-ai-runtime",
      "runtimeRoot": "/Users/golfergeek/projects/golfergeek/apple-ai-runtime",
      "defaultBaseUrl": "http://127.0.0.1:11435/v1",
      "expectedInterfaces": [
        "http-api",
        "cli"
