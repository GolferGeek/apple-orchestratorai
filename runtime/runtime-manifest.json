  "runtimes": [
    {
      "id": "hermes",
      "required": true,
      "managedBy": "app",
      "expectedInterfaces": [
        "http-api",
        "event-stream",
        "cli"
      ],
      "responsibilities": [
        "profiles",
        "skills",
        "workflow-execution",
        "provider-route-policy",
